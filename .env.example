# Copy this file to .env.local for local dev (Next.js loads .env.local
# automatically). Never commit .env.local — it's gitignored.

# Long random string used to HMAC-sign session cookies. Required in
# production. If unset, autobank falls back to a hardcoded dev secret —
# DO NOT rely on that in any deployed environment.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional admin passcode for the create-room endpoint. When set, every
# POST /api/rooms request must include `instancePasscode` matching this
# value or it returns 401. Prevents random visitors from creating rooms
# on your deployed instance. Leave blank for fully-open dev.
INSTANCE_PASSCODE=

# Optional Redis connection string. When set, autobank uses Redis for
# room storage and SSE pub/sub fan-out (required for multi-instance
# deployments). When unset, falls back to an in-process MemoryStore that
# only works for single-instance dev.
# Local Docker:  REDIS_URL=redis://localhost:6379
# Upstash:       provided by the Vercel Marketplace integration.
REDIS_URL=
